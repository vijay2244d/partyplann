---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <section class="reviews-section">
    <div class="container">
      <h1 class="section-title">What Our Clients Say</h1>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="stars">★★★★★</div>
          <p class="review-text">"Party Time made my daughter's birthday unforgettable! The planning was seamless, and the team was so creative. Highly recommend!"</p>
          <p class="reviewer-name">- Sarah L.</p>
        </div>
        <div class="review-card">
          <div class="stars">★★★★★</div>
          <p class="review-text">"We used Party Time for our corporate event, and they exceeded all our expectations. Professional, organized, and truly top-notch service."
          </p>
          <p class="reviewer-name">- David R.</p>
        </div>
        <div class="review-card">
          <div class="stars">★★★★★</div>
          <p class="review-text">"The best party planners in the business! They took care of every detail, allowing us to just enjoy the celebration. It was magical."
          </p>
          <p class="reviewer-name">- Emily W.</p>
        </div>
        <div class="review-card">
          <div class="stars">★★★★★</div>
          <p class="review-text">"From the theme to the catering, everything was perfect. The team at Party Time is passionate about what they do, and it shows!"
          </p>
          <p class="reviewer-name">- Michael B.</p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .reviews-section {
    padding: 4rem 1rem;
    background-color: var(--background-color);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    text-align: center;
    font-size: 2.5rem;
    color: var(--text-color);
    margin-bottom: 3rem;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .review-card {
    background-color: var(--card-bg-color, #f9f9f9);
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
  }

  .stars {
    font-size: 1.5rem;
    color: #ffc107;
    margin-bottom: 1rem;
  }

  .review-text {
    font-style: italic;
    color: var(--text-color);
    flex-grow: 1;
    margin-bottom: 1rem;
  }

  .reviewer-name {
    font-weight: 600;
    color: var(--logo-color);
    text-align: right;
  }
</style>
