---

<MainLayout>
  <section id="reviews" class="reviews-section">
    <div class="container">
      <h2 class="section-title">What Our Clients Say</h2>
      <div class="reviews-grid">
        {reviews.map((review) => (
          <div class="review-card">
            <p class="review-text">"{review.review}"</p>
            <p class="review-name">- {review.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .reviews-section {
    padding: 5rem 2rem;
  }

  .section-title {
    font-size: 3rem;
    margin-bottom: 3rem;
    color: #333;
    text-align: center;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .review-card {
    background: #fff;
    padding: 2rem;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .review-text {
    font-size: 1.1rem;
    font-style: italic;
    margin-bottom: 1rem;
  }

  .review-name {
    font-weight: 700;
    text-align: right;
  }
</style>
