---
import MainLayout from '../layouts/MainLayout.astro';

const reviews = [
  {
    name: 'John Doe',
    position: 'Happy Customer',
    testimonial: 'AstroParty made my daughter’s birthday unforgettable! The planning was seamless, and the execution was flawless. I couldn’t have asked for a better experience.',
    avatar: 'https://i.pravatar.cc/150?u=a042581f4e29026704d'
  },
  {
    name: 'Jane Smith',
    position: 'Corporate Client',
    testimonial: 'We hired AstroParty for our annual company event, and they exceeded all our expectations. The team was professional, creative, and incredibly organized. Highly recommended!',
    avatar: 'https://i.pravatar.cc/150?u=a042581f4e29026705d'
  },
  {
    name: 'David Johnson',
    position: 'Groom-to-be',
    testimonial: 'The bachelor party was a massive hit, all thanks to AstroParty. They took care of every detail, allowing me and my friends to just relax and have a great time.',
    avatar: 'https://i.pravatar.cc/150?u=a042581f4e29026706d'
  },
    {
    name: 'Michael Brown',
    position: 'Event Planner',
    testimonial: 'I collaborate with AstroParty on many events, and they are my go-to team for a reason. Their creativity and attention to detail are unmatched. Every event is a success.',
    avatar: 'https://i.pravatar.cc/150?u=a042581f4e29026707d'
  },
  {
    name: 'Emily White',
    position: 'Bride-to-be',
    testimonial: 'AstroParty planned my bridal shower, and it was absolutely magical. The decorations, the activities, everything was perfect. I can’t wait for them to plan my wedding!',
    avatar: 'https://i.pravatar.cc/150?u=a042581f4e29026708d'
  },
  {
    name: 'Chris Green',
    position: 'Satisfied Customer',
    testimonial: 'If you want a stress-free party planning experience, look no further than AstroParty. They are the best in the business. I will definitely be using their services again!',
    avatar: 'https://i.pravatar.cc/150?u=a042581f4e29026709d'
  }
];
---

<MainLayout>
  <section class="reviews-section">
    <div class="container">
      <h1 class="section-title">What Our Clients Say</h1>
      <div class="reviews-grid">
        {reviews.map(review => (
          <div class="review-card">
            <p class="testimonial">"{review.testimonial}"</p>
            <div class="author-info">
              <img src={review.avatar} alt={review.name} class="avatar">
              <div>
                <p class="author-name">{review.name}</p>
                <p class="author-position">{review.position}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .reviews-section {
    padding: 4rem 1rem;
    background-color: var(--background-color);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    text-align: center;
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    color: var(--text-color);
    margin-bottom: 3rem;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
  }

  .review-card {
    background-color: var(--card-bg-color, #f9f9f9);
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .review-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }

  .testimonial {
    font-family: 'Roboto', sans-serif;
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--text-color);
    margin: 0 0 1.5rem 0;
  }

  .author-info {
    display: flex;
    align-items: center;
  }

  .avatar {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    margin-right: 1rem;
  }

  .author-name {
    font-weight: 700;
    color: var(--text-color);
    margin: 0;
  }

  .author-position {
    color: var(--text-color);
    opacity: 0.8;
    margin: 0;
  }
</style>
