---
import MainLayout from '../layouts/MainLayout.astro';

const reviews = [
  {
    name: "Alex Johnson",
    review: "The birthday party for my son was a massive success! AstroParty's team was professional and handled everything from decorations to entertainment. The space theme was out of this world!",
  },
  {
    name: "Samantha Lee",
    review: "Our company's annual gala was flawlessly executed by AstroParty. Their attention to detail and creative ideas made it a memorable night for everyone. True professionals.",
  },
  {
    name: "Michael & Emily Carter",
    review: "I can't thank AstroParty enough for making our wedding day perfect. They listened to our vision and brought it to life beautifully. It was a stress-free and magical experience.",
  },
  {
    name: "Jessica Chen, CEO of InnovateX",
    review: "Hired them for a product launch event, and the results were phenomenal. AstroParty created an immersive brand experience that wowed our clients and partners.",
  },
  {
    name: "David Rodriguez",
    review: "From the custom cocktails to the live band, every single detail of our anniversary party was perfect. AstroParty's team is creative, organized, and a joy to work with.",
  },
  {
    name: "Maria Garcia",
    review: "The baby shower was absolutely adorable! AstroParty took my scattered ideas and turned them into a cohesive, beautiful event. All the guests were so impressed.",
  },
  {
    name: "The Franklin Family",
    review: "We've used AstroParty for several family gatherings, and they never disappoint. Their ability to adapt to different themes and scales is impressive. Highly recommended!",
  },
  {
    name: "Dr. Eleanor Vance",
    review: "AstroParty organized a charity fundraiser for us, and their expertise helped us exceed our fundraising goals. The event was elegant, well-managed, and impactful.",
  },
  {
    name: "Tom Wilson",
    review: "The superhero training academy party for my 6-year-old was epic! The actors were fantastic with the kids, and the activities were so creative. Best party ever, according to my son!",
  },
];
---

<MainLayout>
  <section id="reviews" class="reviews-section">
    <div class="container">
      <h2 class="section-title">What Our Clients Say</h2>
      <div class="reviews-grid">
        {reviews.map((review) => (
          <div class="review-card">
            <div class="review-quote">“</div>
            <p class="review-text">{review.review}</p>
            <p class="review-name">- {review.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .reviews-section {
    padding: 5rem 2rem;
  }

  .section-title {
    font-size: 3rem;
    margin-bottom: 3rem;
    color: #333;
    text-align: center;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .review-card {
    background: #fff;
    padding: 2.5rem;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .review-quote {
    position: absolute;
    top: -10px;
    left: 15px;
    font-size: 5rem;
    color: #ff69b4;
    opacity: 0.2;
    font-family: 'Pacifico', cursive;
  }

  .review-text {
    font-size: 1.1rem;
    font-style: italic;
    margin-bottom: 1.5rem;
    z-index: 1;
  }

  .review-name {
    font-weight: 700;
    text-align: right;
    z-index: 1;
    color: #555;
  }
</style>
