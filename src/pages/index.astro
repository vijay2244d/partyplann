---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <section class="hero">
    <div class="hero-content">
      <h1 class="title blast-text">Welcome to Party Time!</h1>
      <p class="subtitle">Your one-stop shop for all party needs.</p>
      <a href="/services" class="cta-button">Our Services</a>
    </div>
  </section>
</MainLayout>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    height: calc(100vh - 120px); /* Adjusted for potential header/footer height */
    padding: 0 1rem;
  }

  .hero-content {
    /* Content is already centered by .hero */
  }

  .title {
    font-family: 'Pacifico', cursive;
    font-size: 5rem; 
    min-height: 1.5em; /* Prevent layout shift during animation */
    color: #333;
  }

  .subtitle {
    font-size: 1.5rem;
    color: #666;
    margin: 1.5rem 0;
  }

  .cta-button {
    display: inline-block;
    background-color: #8a4baf;
    color: #fff;
    padding: 0.8rem 2.5rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1.1rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(138, 75, 175, 0.3);
  }

  .blast-text {
    opacity: 1; /* Container must be visible */
  }

  @keyframes popper-blast-in {
    from { opacity: 0; transform: translate(var(--start-x), var(--start-y)) scale(1.5) rotate(var(--start-rot)); }
    to { opacity: 1; transform: translate(0, 0) scale(1) rotate(0); }
  }

  .blast-text span {
    display: inline-block;
    opacity: 0; /* Initially hidden */
  }

  .blast-text.animate span {
    animation-name: popper-blast-in;
    animation-duration: 0.8s;
    animation-timing-function: cubic-bezier(0.175, 0.885, 0.32, 1.275);
    animation-fill-mode: forwards;
  }

  /* Responsive Styles */
  @media (max-width: 768px) {
    .title {
      font-size: 3.5rem; /* Reduce font size for tablets and mobiles */
    }
    .subtitle {
      font-size: 1.2rem;
    }
    .hero {
      height: calc(80vh - 100px);
    }
  }

  @media (max-width: 480px) {
    .title {
      font-size: 2.8rem; /* Further reduce for small mobile screens */
    }
    .subtitle {
      font-size: 1rem;
    }
    .cta-button {
      padding: 0.7rem 2rem;
      font-size: 1rem;
    }
  }

</style>

<script>
  function setupPopperAnimation() {
    const textElement = document.querySelector('.blast-text');
    if (!textElement || textElement.classList.contains('animate')) {
      return;
    }
    const text = textElement.textContent.trim();
    textElement.textContent = '';
    for (let i = 0; i < text.length; i++) {
      const letter = text[i];
      const span = document.createElement('span');
      span.textContent = letter;
      if (letter.trim() === '') { span.style.width = '0.5em'; }
      span.style.setProperty('--start-x', `${Math.random() * 400 - 200}px`);
      span.style.setProperty('--start-y', `${Math.random() * 300 - 150}px`);
      span.style.setProperty('--start-rot', `${Math.random() * 90 - 45}deg`);
      span.style.animationDelay = `${i * 0.035}s`;
      textElement.appendChild(span);
    }
    textElement.classList.add('animate');
  }
  document.addEventListener('astro:page-load', setupPopperAnimation);
  setupPopperAnimation();
</script>
