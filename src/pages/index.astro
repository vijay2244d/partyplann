---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <section class="hero">
    <div class="hero-content">
      <h1 class="title blast-text">Welcome to Party Time!</h1>
      <p class="subtitle">Your one-stop shop for all party needs.</p>
    </div>
  </section>
</MainLayout>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    height: calc(100vh - 120px); 
    padding: 0 1rem;
    background-color: #0d001c; /* Slightly darker background */
    overflow: hidden;
  }

  .hero::before,
  .hero::after,
  .hero-content::before {
    content: '';
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(150px);
    will-change: transform, opacity;
  }

  .hero::before {
    background-image: radial-gradient(circle, #ff5e62 0%, transparent 50%);
    animation: aurora-1 15s ease-in-out infinite alternate;
  }

  .hero::after {
    background-image: radial-gradient(circle, #8a4baf 0%, transparent 50%);
    animation: aurora-2 18s ease-in-out infinite alternate;
  }

  .hero-content::before {
    background-image: radial-gradient(circle, #00c6ff 0%, transparent 50%);
    animation: aurora-3 20s ease-in-out infinite alternate;
  }

  @keyframes aurora-1 {
    0% { transform: translate(-30%, -40%) scale(1); opacity: 0.6; }
    50% { transform: translate(40%, 50%) scale(1.4); opacity: 0.4; }
    100% { transform: translate(-30%, -40%) scale(1); opacity: 0.6; }
  }

  @keyframes aurora-2 {
    0% { transform: translate(30%, 40%) scale(1.2); opacity: 0.5; }
    50% { transform: translate(-40%, -30%) scale(1); opacity: 0.7; }
    100% { transform: translate(30%, 40%) scale(1.2); opacity: 0.5; }
  }

  @keyframes aurora-3 {
    0% { transform: translate(0, 0) scale(1); opacity: 0.3; }
    50% { transform: translate(10%, -10%) scale(1.5); opacity: 0.5; }
    100% { transform: translate(0, 0) scale(1); opacity: 0.3; }
  }

  .hero-content {
    z-index: 1;
    position: relative; /* Needed for the ::before pseudo-element */
  }

  .title {
    font-family: 'Pacifico', cursive;
    font-size: 5rem; 
    min-height: 1.5em; 
    color: #f0e6ff;
  }

  .subtitle {
    font-size: 1.5rem;
    color: #f0e6ff;
    margin: 1.5rem 0;
  }

  .blast-text {
    opacity: 1; 
  }

  @keyframes popper-blast-in {
    from { opacity: 0; transform: translate(var(--start-x), var(--start-y)) scale(1.5) rotate(var(--start-rot)); }
    to { opacity: 1; transform: translate(0, 0) scale(1) rotate(0); }
  }

  .blast-text span {
    display: inline-block;
    opacity: 0; 
  }

  .blast-text.animate span {
    animation-name: popper-blast-in;
    animation-duration: 0.8s;
    animation-timing-function: cubic-bezier(0.175, 0.885, 0.32, 1.275);
    animation-fill-mode: forwards;
  }

  @media (max-width: 768px) {
    .title { font-size: 3.5rem; }
    .subtitle { font-size: 1.2rem; }
    .hero { height: calc(80vh - 100px); }
  }

  @media (max-width: 480px) {
    .title { font-size: 2.8rem; }
    .subtitle { font-size: 1rem; }
  }
</style>

<script>
  function setupPopperAnimation() {
    const textElement = document.querySelector('.blast-text');
    if (!textElement || textElement.classList.contains('animate')) {
      return;
    }
    const text = textElement.textContent.trim();
    textElement.textContent = '';
    for (let i = 0; i < text.length; i++) {
      const letter = text[i];
      const span = document.createElement('span');
      span.textContent = letter;
      if (letter.trim() === '') { span.style.width = '0.5em'; }
      span.style.setProperty('--start-x', `${Math.random() * 400 - 200}px`);
      span.style.setProperty('--start-y', `${Math.random() * 300 - 150}px`);
      span.style.setProperty('--start-rot', `${Math.random() * 90 - 45}deg`);
      span.style.animationDelay = `${i * 0.035}s`;
      textElement.appendChild(span);
    }
    textElement.classList.add('animate');
  }
  document.addEventListener('astro:page-load', setupPopperAnimation);
  setupPopperAnimation();
</script>
