---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <section class="hero">
    <div class="aurora-background">
      <div class="aurora-blob"></div>
      <div class="aurora-blob"></div>
      <div class="aurora-blob"></div>
    </div>
    <div class="hero-content">
      <h1 class="title blast-text">Welcome to Party Time!</h1>
      <p class="subtitle">Your one-stop shop for all party needs.</p>
    </div>
  </section>
</MainLayout>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    height: calc(100vh - 120px); 
    padding: 0 1rem;
    background-color: #01010c;
    overflow: hidden;
  }

  .aurora-background {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 140vmax;
    height: 140vmax;
    transform: translate(-50%, -50%);
    animation: rotateBackground 40s linear infinite;
  }

  @keyframes rotateBackground {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  .aurora-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
  }

  .aurora-blob:nth-child(1) {
    width: 80vmax;
    height: 80vmax;
    top: 5%;
    left: 10%;
    background-color: rgba(255, 182, 193, 0.4);
    animation: moveBlob1 12s infinite alternate;
  }

  .aurora-blob:nth-child(2) {
    width: 90vmax;
    height: 90vmax;
    top: 15%;
    right: 5%;
    background-color: rgba(173, 216, 230, 0.4);
    animation: moveBlob2 16s infinite alternate;
  }

  .aurora-blob:nth-child(3) {
    width: 70vmax;
    height: 70vmax;
    bottom: 5%;
    left: 25%;
    background-color: rgba(230, 230, 250, 0.4);
    animation: moveBlob3 20s infinite alternate;
  }

  @keyframes moveBlob1 {
    from { transform: translate(0, 0) scale(1); }
    to { transform: translate(5vmax, 10vmax) scale(1.1); }
  }

  @keyframes moveBlob2 {
    from { transform: translate(0, 0) scale(1); }
    to { transform: translate(-10vmax, 5vmax) scale(0.9); }
  }

  @keyframes moveBlob3 {
    from { transform: translate(0, 0) scale(1); }
    to { transform: translate(10vmax, -5vmax) scale(1.2); }
  }

  .hero-content {
    z-index: 1;
    position: relative;
  }

  .title {
    font-family: 'Pacifico', cursive;
    font-size: 5rem; 
    min-height: 1.5em; 
    color: #f0e6ff;
  }

  .subtitle {
    font-size: 1.5rem;
    color: #f0e6ff;
    margin: 1.5rem 0;
  }

  .blast-text {
    opacity: 1; 
  }

  @keyframes popper-blast-in {
    from { opacity: 0; transform: translate(var(--start-x), var(--start-y)) scale(1.5) rotate(var(--start-rot)); }
    to { opacity: 1; transform: translate(0, 0) scale(1) rotate(0); }
  }

  .blast-text span {
    display: inline-block;
    opacity: 0; 
  }

  .blast-text.animate span {
    animation-name: popper-blast-in;
    animation-duration: 0.8s;
    animation-timing-function: cubic-bezier(0.175, 0.885, 0.32, 1.275);
    animation-fill-mode: forwards;
  }

  @media (max-width: 768px) {
    .title { font-size: 3.5rem; }
    .subtitle { font-size: 1.2rem; }
    .hero { height: calc(80vh - 100px); }
  }

  @media (max-width: 480px) {
    .title { font-size: 2.8rem; }
    .subtitle { font-size: 1rem; }
  }
</style>

<script>
  function setupPopperAnimation() {
    const textElement = document.querySelector('.blast-text');
    if (!textElement || textElement.classList.contains('animate')) {
      return;
    }
    const text = textElement.textContent.trim();
    textElement.textContent = '';
    for (let i = 0; i < text.length; i++) {
      const letter = text[i];
      const span = document.createElement('span');
      span.textContent = letter;
      if (letter.trim() === '') { span.style.width = '0.5em'; }
      span.style.setProperty('--start-x', `${Math.random() * 400 - 200}px`);
      span.style.setProperty('--start-y', `${Math.random() * 300 - 150}px`);
      span.style.setProperty('--start-rot', `${Math.random() * 90 - 45}deg`);
      span.style.animationDelay = `${i * 0.035}s`;
      textElement.appendChild(span);
    }
    textElement.classList.add('animate');
  }
  document.addEventListener('astro:page-load', setupPopperAnimation);
  setupPopperAnimation();
</script>