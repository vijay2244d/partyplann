---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <section class="consultation-section">
    <div class="container">
      <div class="consultation-wrapper">
        <div class="consultation-form-column">
          <div class="consultation-form-wrapper">
            <h2>Book Your Consultation</h2>
            <form action="#" method="post">
              <div class="form-group">
                <label for="full-name">Full Name</label>
                <input type="text" id="full-name" name="full-name" placeholder="John Doe">
              </div>
              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="you@example.com">
              </div>
              <div class="form-group">
                <label for="phone">Phone Number</label>
                <input type="tel" id="phone" name="phone" placeholder="(123) 456-7890">
              </div>
              <div class="form-group">
                <label for="event-type">Type of Event</label>
                <input type="text" id="event-type" name="event-type" placeholder="e.g., Birthday, Wedding, Corporate">
              </div>
              <div class="form-group">
                <label for="message">Tell Us About Your Vision</label>
                <textarea id="message" name="message" rows="5" placeholder="What are you imagining for your event?"></textarea>
              </div>
              <button type="submit" class="cta-button">Get My Quote</button>
            </form>
          </div>
        </div>
        <div class="consultation-description-column">
          <div class="description-content">
              <h3>Let's Create Something <span>Unforgettable.</span></h3>
              <p>Your event is more than just a date on the calendar—it's a story waiting to be told. Our team of expert planners is here to listen to your vision and turn it into a vibrant reality. From the grandest gestures to the smallest details, we handle everything with precision and flair.</p>
              <p>Book a no-obligation consultation today and let's explore the possibilities together. Your dream event is just a conversation away.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .consultation-section {
    padding: 5rem 1rem;
    background-color: var(--background-color);
    font-family: 'Roboto', sans-serif;
    min-height: 90vh;
    display: flex;
    align-items: center;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .consultation-wrapper {
    display: flex;
    background-color: var(--card-bg-color, #ffffff);
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    overflow: hidden;
  }

  .consultation-form-column {
    flex: 0 0 60%;
    padding: 4rem;
  }
  
  .consultation-description-column {
    flex: 0 0 40%;
    background: linear-gradient(145deg, #8a4baf, #c4a7e7);
    color: white;
    padding: 4rem;
    text-align: left;
  }
  
  .description-content{
    max-width: 400px;
  }

  .description-content h3 {
    font-family: 'Playfair Display', serif;
    font-size: 2.8rem;
    margin: 0;
    line-height: 1.2;
  }
  
  .description-content h3 span {
    color: #f0e6ff;
    display: block;
  }

  .description-content p {
    font-size: 1.1rem;
    line-height: 1.8;
    margin-top: 2.5rem;
    opacity: 0.9;
  }

  .consultation-form-wrapper h2 {
    text-align: center;
    color: var(--text-color);
    margin-bottom: 2.5rem;
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  label {
    display: block;
    margin-bottom: .5rem;
    color: var(--text-color);
    font-weight: 600;
  }

  input, textarea {
    width: 100%;
    padding: .85rem;
    border: 1px solid var(--input-border-color, #ddd);
    border-radius: 6px;
    background-color: var(--input-bg-color, #f9f9f9);
    color: var(--text-color);
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  input:focus, textarea:focus {
    outline: none;
    border-color: #8a4baf;
    box-shadow: 0 0 0 3px rgba(138, 75, 175, 0.2);
  }
  
  .cta-button {
    width: 100%;
    padding: 1rem;
    border: none;
    border-radius: 6px;
    background-color: var(--cta-bg, #8a4baf);
    color: var(--cta-text-color, white);
    font-weight: 700;
    font-size: 1.1rem;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }
  
  .cta-button:hover {
    background-color: #733c94; /* Darker shade for hover */
    transform: translateY(-2px);
  }
  
  @media (max-width: 992px) {
    .consultation-wrapper {
        flex-direction: column;
    }
    .consultation-form-column, .consultation-description-column {
        padding: 3rem;
    }
  }

</style>
