---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <section class="schedule-section">
    <div class="container">
      <h2 class="section-title">Schedule an Appointment</h2>
      <div class="schedule-form-wrapper">
        <form action="#" method="POST">
          <div class="form-group">
            <label for="sched-name">Your Name</label>
            <input type="text" id="sched-name" name="name" required>
          </div>
          <div class="form-group">
            <label for="sched-email">Your Email</label>
            <input type="email" id="sched-email" name="email" required>
          </div>
          <div class="form-group">
            <label for="sched-phone">Your Phone Number</label>
            <input type="tel" id="sched-phone" name="phone" required>
          </div>
          <div class="form-group">
            <label for="sched-date">Event Date</label>
            <input type="date" id="sched-date" name="date" required>
          </div>
          <button type="submit" class="cta-button">Submit Request</button>
        </form>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .schedule-section {
    padding: 5rem 2rem;
  }

  .section-title {
    font-size: 3rem;
    margin-bottom: 3rem;
    color: #333;
    text-align: center;
  }

  .schedule-form-wrapper {
    max-width: 600px;
    margin: 0 auto;
    background: #fff;
    padding: 2rem;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  input,
  textarea {
    width: 100%;
    padding: 1rem;
    border: 1px solid #ccc;
    border-radius: 5px;
    font-family: 'Poppins', sans-serif;
  }

  .cta-button {
    display: inline-block;
    padding: 1rem 2rem;
    background: #ff69b4;
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    width: 100%;
  }

  .cta-button:hover {
    background: #ff1493;
    transform: scale(1.05);
  }
</style>
