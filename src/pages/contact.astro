---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <!-- Shaking Call Icon Animation -->
  <div id="phone-animation-container">
    <svg class="call-icon" xmlns="http://www.w3.org/2000/svg" height="100" viewBox="0 96 960 960" width="100">
        <path d="M798 894q-125 0-247-54.5T329 707q-99-99-153.5-221T121 239q0-13 9-22t22-9h139q11 0 20 6.5t12 15.5l57 210q5 17-1 32t-18 24L323 535q30 54 70 100t88 88q56 40 100 70l41-38q10-9 24-18t32-1l210 57q9 3 15.5 12t6.5 20v139q0 13-9 22t-22 9Z"/>
    </svg>
    <p class="call-message">Click to get in touch</p>
  </div>

  <section class="contact-section" style="display: none;">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-form-wrapper">
          <h2>Send a Message</h2>
          <form action="#" method="post">
            <div class="form-group-row">
              <div class="form-group">
                <label for="full-name">Full Name</label>
                <input type="text" id="full-name" name="full-name" placeholder="John Doe">
              </div>
              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="you@example.com">
              </div>
            </div>
            <div class="form-group">
              <label for="address-map">Address (for Map)</label>
              <input type="text" id="address-map" name="address-map" placeholder="Click on the map to select a location">
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" placeholder="Project Inquiry">
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" placeholder="Tell us about your project or question..."></textarea>
            </div>
            <button type="submit" class="cta-button">Send Message</button>
          </form>
        </div>

        <div class="contact-info-wrapper">
          <div class="contact-info-card">
            <h3>Contact Information</h3>
            <div class="contact-item">
              <p><strong>Email</strong><br>contact@mdconstruction.com</p>
            </div>
            <div class="contact-item phone-item">
              <span class="phone-icon"></span>
              <p><strong>Phone</strong><br>7810071916</p>
            </div>
            <div class="contact-item">
              <p><strong>Address</strong><br>Madurai</p>
            </div>
          </div>
          
          <div class="location-card">
            <h3>Your Location</h3>
            <div id="map"></div>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .contact-section {
    padding: 4rem 1rem;
    background-color: var(--background-color);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
  }

  .contact-form-wrapper, .contact-info-card, .location-card {
    background-color: var(--card-bg-color, #f9f9f9);
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  }
  
  h2, h3 {
    color: var(--text-color);
    margin-bottom: 1.5rem;
  }
  
  .form-group-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .form-group-row .form-group {
    flex: 1;
    margin-bottom: 0;
  }

  .form-group {
    margin-bottom: 1rem;
  }

  label {
    display: block;
    margin-bottom: .5rem;
    color: var(--text-color);
    font-weight: 600;
  }

  input, textarea {
    width: 100%;
    padding: .75rem;
    border: 1px solid var(--input-border-color, #ccc);
    border-radius: 4px;
    background-color: var(--input-bg-color, #fff);
    color: var(--text-color);
  }
  
  .cta-button {
    width: 100%;
    padding: 1rem;
    border: none;
    border-radius: 4px;
    background-color: var(--cta-bg);
    color: var(--cta-text-color);
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }
  
  .cta-button:hover {
    opacity: 0.9;
  }
  
  .contact-info-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .contact-item p {
    margin: 0;
    color: var(--text-color);
  }

  .phone-icon {
    display: inline-block;
    width: 24px;
    height: 24px;
    background-color: var(--logo-color);
    -webkit-mask: url('data:image/svg+xml;charset=UTF-8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23000000"><path d="M0 0h24v24H0z" fill="none"/><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>') no-repeat center;
    mask: url('data:image/svg+xml;charset=UTF-8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23000000"><path d="M0 0h24v24H0z" fill="none"/><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>') no-repeat center;
    animation: shake 1.5s infinite;
  }

  @keyframes shake {
    0%, 100% { transform: rotate(0); }
    10%, 30%, 50%, 70%, 90% { transform: rotate(-10deg); }
    20%, 40%, 60%, 80% { transform: rotate(10deg); }
  }

  #map {
    height: 250px;
    border-radius: 4px;
  }
  
  #phone-animation-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: #f9f4fB; /* Lighter background */
    z-index: 100;
    opacity: 1;
    transition: opacity 1s ease-in-out;
    cursor: pointer;
  }
  #phone-animation-container.fade-out {
    opacity: 0;
    pointer-events: none;
  }

  .call-message {
    font-family: 'Pacifico', cursive;
    font-size: 2rem;
    color: #555;
    margin-top: 2rem;
  }

  .call-icon {
    animation: shake 0.8s cubic-bezier(.36,.07,.19,.97) both infinite;
    fill: #8a4baf;
  }

  @media (max-width: 992px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
  
  @media (max-width: 576px) {
    .form-group-row {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>

<script is:inline>
  function initMap() {
    setTimeout(() => {
      const mapElement = document.getElementById('map');
      if (mapElement && typeof L !== 'undefined' && !mapElement._leaflet_id) {
        const map = L.map(mapElement).setView([9.9252, 78.1198], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(map);

        let marker;

        map.on('click', function(e) {
          const lat = e.latlng.lat;
          const lon = e.latlng.lng;
          const addressInput = document.getElementById('address-map');

          if (marker) {
            map.removeLayer(marker);
          }

          marker = L.marker([lat, lon]).addTo(map);

          fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}`)
            .then(response => response.json())
            .then(data => {
              if (addressInput) {
                addressInput.value = data.display_name || 'Address not found';
              }
            })
            .catch(error => {
              console.error('Error fetching address:', error);
              if (addressInput) {
                addressInput.value = 'Could not retrieve address';
              }
            });
        });
      }
    }, 100);
  }

  document.addEventListener('astro:page-load', initMap);
  document.addEventListener('DOMContentLoaded', () => {
    const animationContainer = document.getElementById('phone-animation-container');
    const contactSection = document.querySelector('.contact-section');

    if (animationContainer && contactSection) {
      animationContainer.addEventListener('click', () => {
        animationContainer.classList.add('fade-out');
        contactSection.style.display = 'block';
      });
    }
  });
</script>
