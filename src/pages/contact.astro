
---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-form-wrapper intro-animate">
          <h2>Send a Message</h2>
          <form action="#" method="post">
            <div class="form-group-row">
              <div class="form-group">
                <label for="full-name">Full Name</label>
                <input type="text" id="full-name" name="full-name" placeholder="John Doe">
              </div>
              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="you@example.com">
              </div>
            </div>
            <div class="form-group">
              <label for="address-map">Address (for Map)</label>
              <input type="text" id="address-map" name="address-map" placeholder="Click on the map to select a location">
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" placeholder="Project Inquiry">
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" placeholder="Tell us about your project or question..."></textarea>
            </div>
            <button type="submit" class="cta-button">Send Message</button>
          </form>
        </div>

        <div class="contact-info-wrapper intro-animate" style="transition-delay: 0.2s;">
          <div class="contact-info-card">
            <h3>Contact Information</h3>
            <div class="contact-item">
              <p><strong>Email</strong><br>contact@mdconstruction.com</p>
            </div>
            <div class="contact-item phone-item">
              <svg class="phone-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
              <p><strong>Phone</strong><br>7810071916</p>
            </div>
            <div class="contact-item">
              <p><strong>Address</strong><br>Madurai</p>
            </div>
          </div>
          
          <div class="location-card">
            <h3>Your Location</h3>
            <div id="map"></div>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .contact-section { padding: 4rem 1rem; background-color: var(--background-color); overflow: hidden; }
  .container { max-width: 1200px; margin: 0 auto; }
  .contact-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; }
  .contact-form-wrapper, .contact-info-card, .location-card { background-color: var(--card-bg-color, #f9f9f9); padding: 2rem; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
  h2, h3 { color: var(--text-color); margin-bottom: 1.5rem; }
  .form-group-row { display: flex; gap: 1rem; margin-bottom: 1rem; }
  .form-group-row .form-group { flex: 1; margin-bottom: 0; }
  .form-group { margin-bottom: 1rem; }
  label { display: block; margin-bottom: .5rem; color: var(--text-color); font-weight: 600; }
  input, textarea { width: 100%; padding: .75rem; border: 1px solid var(--input-border-color, #ccc); border-radius: 4px; background-color: var(--input-bg-color, #fff); color: var(--text-color); }
  .cta-button { width: 100%; padding: 1rem; border: none; border-radius: 4px; background-color: var(--cta-bg); color: var(--cta-text-color); font-weight: 600; cursor: pointer; transition: background-color 0.3s ease; }
  .cta-button:hover { opacity: 0.9; }
  .contact-info-wrapper { display: flex; flex-direction: column; gap: 2rem; }
  .contact-item { display: flex; align-items: center; gap: 1rem; }
  .contact-item p { margin: 0; color: var(--text-color); }
  
  .phone-icon {
    width: 28px;
    height: 28px;
    fill: var(--logo-color);
    transform: scale(0);
    animation: pop-in 0.5s cubic-bezier(0.68, -0.55, 0.27, 1.55) 0.8s forwards,
               shake 1.5s ease-in-out 1.4s infinite;
  }

  @keyframes pop-in {
    from { transform: scale(0); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  @keyframes shake {
    0%, 100% { transform: rotate(0); }
    10%, 30%, 50% { transform: rotate(-8deg); }
    20%, 40%, 60% { transform: rotate(8deg); }
  }

  #map { height: 250px; border-radius: 4px; }
  
  .intro-animate {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  
  .intro-animate.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 992px) { .contact-grid { grid-template-columns: 1fr; } }
  @media (max-width: 576px) { .form-group-row { flex-direction: column; gap: 1rem; } }
</style>

<script is:inline>
  function playIntro() {
    const elements = document.querySelectorAll('.intro-animate');
    elements.forEach(el => {
      // A short delay to ensure the page is painted before we animate
      setTimeout(() => {
        el.classList.add('is-visible');
      }, 100);
    });
  }

  function initMap() {
    setTimeout(() => {
      const mapElement = document.getElementById('map');
      if (mapElement && typeof L !== 'undefined' && !mapElement._leaflet_id) {
        const map = L.map(mapElement).setView([9.9252, 78.1198], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(map);

        let marker;

        map.on('click', function(e) {
          const lat = e.latlng.lat;
          const lon = e.latlng.lng;
          const addressInput = document.getElementById('address-map');

          if (marker) {
            map.removeLayer(marker);
          }

          marker = L.marker([lat, lon]).addTo(map);

          fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}`)
            .then(response => response.json())
            .then(data => {
              if (addressInput) {
                addressInput.value = data.display_name || 'Address not found';
              }
            })
            .catch(error => {
              console.error('Error fetching address:', error);
              if (addressInput) {
                addressInput.value = 'Could not retrieve address';
              }
            });
        });
      }
    }, 100);
  }

  document.addEventListener('astro:page-load', () => {
    playIntro();
    initMap();
  });
</script>
