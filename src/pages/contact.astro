---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <!-- Shaking Call Icon Animation -->
  <div id="phone-animation-container">
    <svg class="call-icon" xmlns="http://www.w3.org/2000/svg" height="100" viewBox="0 96 960 960" width="100">
        <path d="M798 894q-125 0-247-54.5T329 707q-99-99-153.5-221T121 239q0-13 9-22t22-9h139q11 0 20 6.5t12 15.5l57 210q5 17-1 32t-18 24L323 535q30 54 70 100t88 88q56 40 100 70l41-38q10-9 24-18t32-1l210 57q9 3 15.5 12t6.5 20v139q0 13-9 22t-22 9Z"/>
    </svg>
    <p class="call-message">Click to get in touch</p>
  </div>

  <!-- Main Content (Initially Hidden) -->
  <section id="contact-section" class="contact-section" hidden>
    <div class="container">
      <h2 class="section-title">Contact Us</h2>
      <div class="contact-wrapper">
        <div class="contact-form-wrapper">
          <form>
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" placeholder="Your Name" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="Your Email" required />
            </div>
            <div class="form-group">
              <label for="place">Place</label>
              <input type="text" id="place" name="place" placeholder="Your Place" required />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" placeholder="Your Message" required></textarea>
            </div>
            <button type="submit" class="cta-button">Send Message</button>
          </form>
        </div>
        <div class="contact-info">
          <h3>Contact Information</h3>
          <p><strong>Email:</strong> contact@astroparty.com</p>
          <p><strong>Phone:</strong> (123) 456-7890</p>
          <p><strong>Address:</strong> 123 Party Lane, Celebration City, USA</p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Animation Container */
  #phone-animation-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: #f9f4fB; /* Lighter background */
    z-index: 100;
    opacity: 1;
    transition: opacity 1s ease-in-out;
    cursor: pointer;
  }
  #phone-animation-container.fade-out {
    opacity: 0;
    pointer-events: none;
  }

  .call-message {
    font-family: 'Pacifico', cursive;
    font-size: 2rem;
    color: #555;
    margin-top: 2rem;
  }

  /* Shaking Call Icon Animation */
  .call-icon {
    animation: shake 0.8s cubic-bezier(.36,.07,.19,.97) both infinite;
    fill: #8a4baf;
  }

  @keyframes shake {
    10%, 90% { transform: translate3d(-1px, 0, 0) rotate(-2deg); }
    20%, 80% { transform: translate3d(2px, 0, 0) rotate(4deg); }
    30%, 50%, 70% { transform: translate3d(-4px, 0, 0) rotate(-6deg); }
    40%, 60% { transform: translate3d(4px, 0, 0) rotate(6deg); }
  }

  /* Main Content */
  .contact-section { padding: 5rem 2rem; opacity: 0; transition: opacity 1s ease-in-out; }
  .contact-section.visible { opacity: 1; }

  .section-title { font-size: 3rem; margin-bottom: 3rem; color: #333; text-align: center; }

  .contact-wrapper { max-width: 1000px; margin: 0 auto; background: #fff; padding: 2rem; border-radius: 10px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1); display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }

  .form-group { margin-bottom: 1.5rem; }

  label { display: block; margin-bottom: 0.5rem; font-weight: 700; }

  input, textarea { width: 100%; padding: 1rem; border: 1px solid #ccc; border-radius: 5px; font-family: 'Poppins', sans-serif; }

  .cta-button { display: inline-block; padding: 1rem 2rem; background: #ff69b4; color: #fff; text-decoration: none; font-weight: 700; border-radius: 50px; border: none; cursor: pointer; transition: all 0.3s ease; width: 100%; }

  .cta-button:hover { background: #ff1493; transform: scale(1.05); }

  .contact-info { padding: 2rem; border-radius: 10px; }

  .contact-info h3 { font-size: 2rem; margin-bottom: 1.5rem; color: #333; }

  .contact-info p { font-size: 1.1rem; margin-bottom: 1rem; }

  @media (max-width: 768px) {
    .contact-wrapper { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const animationContainer = document.getElementById('phone-animation-container');
    const contactSection = document.getElementById('contact-section');

    if (animationContainer && contactSection) {
      const revealContent = () => {
        animationContainer.classList.add('fade-out');
        contactSection.hidden = false;
        setTimeout(() => contactSection.classList.add('visible'), 50);
        animationContainer.removeEventListener('click', revealContent);
      };
      animationContainer.addEventListener('click', revealContent);
    }
  });
</script>
