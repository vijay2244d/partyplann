---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <section id="about" class="about-section">
    <div class="container">
      <h2 class="section-title">About Us</h2>
      <div class="about-content">
        <div class="about-image">
          <img src="https://images.unsplash.com/photo-1527529482837-4698179dc6ce?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="A vibrant and lively party scene with a group of friends enjoying themselves at a beautifully decorated venue. The image captures the energy and excitement of a well-planned event, with colorful decorations, festive lighting, and a joyful atmosphere." />
        </div>
        <div class="about-text">
          <h3>Who We Are</h3>
          <p>
            We are a team of passionate party planners dedicated to creating unforgettable experiences. We believe that every celebration should be special and unique, and we work tirelessly to bring our clients' visions to life. From small, intimate gatherings to large, extravagant events, we handle every detail with precision and care. Our goal is to make the planning process seamless and stress-free, so you can relax and enjoy your special day.
          </p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .about-section {
    padding: 5rem 2rem;
  }

  .section-title {
    font-size: 3rem;
    margin-bottom: 3rem;
    color: #333;
    text-align: center;
  }

  .about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .about-image img {
    width: 100%;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .about-text h3 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    color: #333;
  }
</style>
