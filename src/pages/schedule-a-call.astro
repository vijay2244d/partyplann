---
import MainLayout from '../layouts/MainLayout.astro';
import Calendar from '../components/Calendar.svelte';
---

<MainLayout>
  <section class="schedule-a-call-section">
    <div class="container">
      <h2 class="section-title">Schedule a Call</h2>
      <p class="section-subtitle">We'd love to hear from you. Schedule a call with one of our event planning experts to discuss your needs and how we can help you create an unforgettable experience.</p>
      <div class="schedule-a-call-content">
        <div class="schedule-a-call-form">
          <form id="schedule-a-call-form">
            <div class="form-section">
              <h3 class="form-section-title">Your Information</h3>
              <div class="form-group">
                <label for="name">Your Name</label>
                <input type="text" id="name" name="name" required>
              </div>
              <div class="form-group">
                <label for="email">Your Email</label>
                <input type="email" id="email" name="email" required>
              </div>
            </div>

            <div class="form-section">
              <h3 class="form-section-title">Scheduling</h3>
              <div class="form-group">
                <label for="reason">Reason for Call</label>
                <textarea id="reason" name="reason" rows="5" required></textarea>
              </div>
            </div>

            <div class="form-section">
              <h3 class="form-section-title">Select a Date</h3>
              <div class="form-group" id="calendar-container">
                <Calendar client:load />
                <input type="hidden" id="selected-date" name="selected_date">
              </div>
            </div>

            <button type="submit" class="submit-button">Schedule Call</button>
          </form>
          <div id="thank-you-message" style="display: none; text-align: center;">
            <h4>Thank You!</h4>
            <p>Your call has been scheduled. We will send you a confirmation email shortly.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .schedule-a-call-section {
    padding: 5rem 2rem;
  }

  .section-title {
    font-size: 3rem;
    margin-bottom: 1.5rem;
    color: #333;
    text-align: center;
  }

  .section-subtitle {
    font-size: 1.2rem;
    margin-bottom: 3rem;
    color: #666;
    text-align: center;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .schedule-a-call-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .schedule-a-call-form {
    background: #fff;
    padding: 3rem;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .form-section {
    margin-bottom: 2rem;
  }

  .form-section-title {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: #333;
    border-bottom: 2px solid #ff69b4;
    padding-bottom: 0.5rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ccc;
    border-radius: 5px;
    font-family: 'Poppins', sans-serif;
  }

  .submit-button {
    width: 100%;
    background-color: #ff69b4;
    color: white;
    padding: 1rem;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 700;
    transition: background-color 0.3s ease;
  }

  .submit-button:hover {
    background-color: #ff1493;
  }
</style>
