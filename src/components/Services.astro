---
import ServiceCard from './ServiceCard.svelte';

const services = [
  {
    id: 'birthday',
    icon: '🎉',
    title: 'Birthday Parties',
    description: 'Tell us about your dream birthday party! What theme are you imagining? How many guests are you expecting? Let us handle the magic.'
  },
  {
    id: 'wedding',
    icon: '💍',
    title: 'Weddings',
    description: 'Describe your perfect wedding day. From the venue to the vows, we want to know every detail to make your special day unforgettable.'
  },
  {
    id: 'corporate',
    icon: '👔',
    title: 'Corporate Events',
    description: 'What are the goals for your next corporate event? Whether it is a product launch, a conference, or a team-building retreat, we deliver excellence.'
  },
  {
    id: 'anniversary',
    icon: '💖',
    title: 'Anniversaries',
    description: 'How do you envision celebrating this milestone? Let us help you create a romantic and memorable anniversary celebration.'
  }
];
---

<section id="services" class="services-section">
  <div class="container">
    <h2 class="section-title">Our Services</h2>
    <p class="section-subtitle">A new world of interactive party planning awaits. Click the icons below to see the magic happen!</p>
    <div class="services-grid">
      {services.map((service) => (
          <ServiceCard service={service} client:visible />
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: 5rem 2rem;
    background-color: #f9f4fB;
  }

  .section-title {
    font-family: 'Pacifico', cursive;
    font-size: 3.5rem;
    text-align: center;
    color: #333;
    margin-bottom: 1rem;
  }

  .section-subtitle {
    text-align: center;
    font-size: 1.1rem;
    color: #666;
    margin-bottom: 4rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
    max-width: 1300px;
    margin: 0 auto;
  }

</style>
