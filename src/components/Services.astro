---
import ServiceCard from './ServiceCard.svelte';

const services = [
  {
    icon: '🎉',
    title: 'Birthday Parties',
    description: 'Magical and memorable birthday parties for all ages. We handle everything from decorations and entertainment to catering and cleanup.'
  },
  {
    icon: '💍',
    title: 'Weddings',
    description: 'Full-service wedding planning to make your special day perfect. We handle venue selection, vendor coordination, design, and day-of management.'
  },
  {
    icon: '👔',
    title: 'Corporate Events',
    description: 'Flawless corporate events, from product launches and conferences to holiday parties and team-building retreats. We ensure a professional and engaging experience.'
  },
  {
    icon: '🎈',
    title: 'Other Events',
    description: 'We can plan any type of event you can dream of. Just let us know what you have in mind, and we will make it happen.'
  }
];
---

<section id="services" class="services-section">
  <div class="container">
    <h2 class="section-title">Our Services</h2>
    <div class="services-grid">
      {services.map(service => (
        <ServiceCard client:load service={service} />
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: 5rem 2rem;
  }

  .section-title {
    font-size: 3rem;
    margin-bottom: 3rem;
    color: #333;
    text-align: center;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
</style>