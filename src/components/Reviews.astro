---
// No props needed for this component
---

<section class="reviews-section">
  <div class="container">
    <h2>What Our Clients Say</h2>
    <div class="reviews-grid">
      <div class="review-card">
        <p class="review-text">"The best party planners in the business! They took care of everything and made our event unforgettable."</p>
        <p class="reviewer-name">- Jane Doe</p>
      </div>
      <div class="review-card">
        <p class="review-text">"Highly recommend Party Time for any corporate event. Professional, creative, and a pleasure to work with."</p>
        <p class="reviewer-name">- John Smith</p>
      </div>
      <div class="review-card">
        <p class="review-text">"Our wedding was a dream come true, all thanks to the amazing team at Party Time. They exceeded all our expectations!"</p>
        <p class="reviewer-name">- The Happy Couple</p>
      </div>
    </div>
  </div>
</section>

<style>
  .reviews-section {
    padding: 4rem 2rem;
    background-color: var(--section-bg-light, #f9f9f9);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  h2 {
    font-size: 2.5rem;
    margin-bottom: 3rem;
    color: var(--section-title-color, #333);
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .review-card {
    background: var(--card-bg, white);
    border-radius: 10px;
    box-shadow: var(--card-shadow, 0 5px 15px rgba(0,0,0,0.1));
    padding: 2rem;
    text-align: left;
  }

  .review-text {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--card-text-color, #555);
    margin-bottom: 1rem;
  }

  .reviewer-name {
    font-weight: 700;
    color: var(--card-title-color, #333);
    text-align: right;
  }
</style>
