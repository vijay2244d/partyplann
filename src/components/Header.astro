---
import ThemeToggle from './ThemeToggle.astro';
const { pathname } = Astro.url;
---

<header>
  <nav>
    <div class="logo">
      <a href="/">Party Time</a>
    </div>
    <ul class="nav-links">
      <li><a href="/" class={pathname === "/" ? "active" : ""}>Home</a></li>
      <li><a href="/about" class={pathname === "/about" ? "active" : ""}>About</a></li>
      <li><a href="/services" class={pathname === "/services" ? "active" : ""}>Services</a></li>
      <li><a href="/reviews" class={pathname === "/reviews" ? "active" : ""}>Reviews</a></li>
      <li><a href="/contact" class={pathname === "/contact" ? "active" : ""}>Contact</a></li>
    </ul>
    <div class="actions">
      <ThemeToggle />
      <a href="/consultation" class="cta-button-header">Get a Quote</a>
    </div>
    <div class="hamburger-container">
        <button class="hamburger" aria-label="Toggle menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
  </nav>
</header>

<script src="/src/scripts/header.js"></script>

<style>

  header {
    background: var(--header-bg, white);
    box-shadow: 0 2px 10px var(--header-shadow, rgba(0,0,0,0.1));
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 10;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

.logo a {
    font-family: 'Pacifico', cursive;
    font-size: 2.2rem;
    color: var(--logo-color, #8a4baf);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--nav-link-color, #333);
    font-weight: 600;
    font-size: 1.1rem;
    transition: color 0.3s ease;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -5px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--nav-link-hover-color, #8a4baf);
    transition: width 0.3s ease;
  }

  .nav-links a:hover::after,
  .nav-links a.active::after {
    width: 100%;
  }

  .nav-links a.active {
    color: var(--nav-link-hover-color, #8a4baf);
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .cta-button-header {
    padding: 0.8rem 1.6rem;
    background-color: var(--cta-bg, #8a4baf);
    color: var(--cta-text-color, white) !important;
    text-decoration: none;
    border-radius: 50px;
    font-weight: 700;
    font-size: 1.1rem;
    transition: background-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  .cta-button-header:hover {
    transform: translateY(-2px);
    box-shadow: var(--cta-hover-shadow, 0 5px 15px rgba(138, 75, 175, 0.3));
  }

  .hamburger-container {
    display: none;
  }

  .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      background-color: white;
      padding: 1rem 0;
      box-shadow: 0 5px 10px rgba(0,0,0,0.1);
    }

    .nav-links.active {
      display: flex;
    }

    .actions {
        display: none;
    }

    .hamburger-container {
        display: block;
    }
    
    .hamburger {
        display: flex;
    }
  }

</style>
