---
const { pathname } = Astro.url;
---

<header>
  <nav>
    <div class="logo">
      <a href="/">Party Time</a>
    </div>
    <div class="nav-links">
      <a href="/" class:list={{ "is-active": pathname === "/" }}>Home</a>
      <a href="/about" class:list={{ "is-active": pathname === "/about" }}>About</a>
      <a href="/contact" class:list={{ "is-active": pathname === "/contact" }}>Contact</a>
    </div>
    <div class="actions">
      <a href="/contact" class="cta-button-header">Get a Quote</a>
      
    </div>
    <div class="hamburger-container">
        <button class="hamburger" aria-label="Toggle menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
  </nav>
</header>

<style>

  header {
    background: var(--header-bg, white);
    box-shadow: 0 2px 10px var(--header-shadow, rgba(0,0,0,0.1));
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 10;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  .logo a {
    font-family: 'Pacifico', cursive;
    font-size: 2rem;
    color: var(--logo-color, #8a4baf);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    text-decoration: none;
    font-weight: 700;
    color: var(--nav-link-color, #333);
    transition: color 0.3s ease;
  }

  .nav-links a:hover,
  .nav-links a.is-active {
    color: var(--nav-link-hover-color, #8a4baf);
  }
  
  .actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .cta-button-header {
    padding: 0.75rem 1.5rem;
    background-color: var(--cta-bg, #8a4baf);
    color: var(--cta-text-color, white) !important;
    text-decoration: none;
    border-radius: 50px;
    font-weight: 700;
    transition: background-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  .cta-button-header:hover {
    transform: translateY(-2px);
    box-shadow: var(--cta-hover-shadow, 0 5px 15px rgba(138, 75, 175, 0.3));
  }

  .hamburger-container {
    display: none;
  }

  .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
  }

  .hamburger span {
      display: block;
      width: 25px;
      height: 3px;
      background-color: var(--hamburger-color);
      transition: all 0.3s ease-in-out;
  }

  @media (max-width: 768px) {
    .nav-links, .actions .cta-button-header {
      display: none;
    }

    .hamburger-container {
      display: block;
    }

    .hamburger {
        display: flex;
    }

    nav.is-open .nav-links {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      background: var(--header-bg, white);
      width: 100%;
      padding: 1rem 0;
      box-shadow: 0 4px 10px var(--header-shadow, rgba(0,0,0,0.1));
      align-items: center;
    }
    
    nav.is-open .actions .cta-button-header {
        display: block;
        margin-top: 1rem;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const hamburger = document.querySelector('.hamburger');
    const nav = document.querySelector('nav');

    if (hamburger && nav) {
      hamburger.addEventListener('click', () => {
        nav.classList.toggle('is-open');
      });
    }
  });
</script>
