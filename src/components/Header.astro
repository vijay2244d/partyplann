---
import Counter from './Counter.jsx';
---

<header>
  <div class="logo">
    <a href="/">Party Time</a>
  </div>
  <nav>
    <ul>
      <li><a href="/services">Services</a></li>
      <li><a href="/reviews">Reviews</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="#" id="contact-btn">Contact</a></li>
    </ul>
  </nav>
  <div class="actions">
    <a href="/schedule" class="action-button">Schedule an Appointment</a>
  </div>
</header>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 5%;
    background-color: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .logo a {
    font-family: 'Pacifico', cursive;
    font-size: 2rem;
    color: #c4a7e7;
    text-decoration: none;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  nav a {
    font-size: 1rem;
    color: #333;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s;
  }

  nav a:hover {
    color: #c4a7e7;
  }

  .action-button {
    background-color: #c4a7e7;
    color: white;
    padding: 0.8rem 1.5rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    transition: background-color 0.3s, transform 0.2s;
    box-shadow: 0 4px 15px rgba(196, 167, 231, 0.4);
  }

  .action-button:hover {
    background-color: #b390d6;
    transform: translateY(-2px);
  }
</style>
