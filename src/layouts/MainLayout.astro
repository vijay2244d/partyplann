---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<script>
  // No script needed for this component
</script>

<style is:global>
  /* CSS Reset & Base Styles */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 16px; scroll-behavior: smooth; }
  body { font-family: 'Poppins', sans-serif; background-color: #F9F4FB; color: #333; line-height: 1.6; }
  img { max-width: 100%; height: auto; display: block; }
  h1, h2, h3, h4 { line-height: 1.2; margin-bottom: 1rem; }

  /* Main Layout Structure */
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  main {
    flex-grow: 1;
    padding: 2rem;
  }

  /* Utility Classes */
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; }
  .text-center { text-align: center; }

  /* Header & Footer */
  /* These will be styled in their own components */
</style>

<style>
  /* Scoped styles for the layout component can go here if needed */
</style>

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Party Time - Plan Your Perfect Event</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&family=Pacifico&display=swap" rel="stylesheet">
  
  <style>
    #phone-animation-overlay { /* styles... */ }
    .phone-icon { /* styles... */ }
    @keyframes ring { /* styles... */ }
    .click-to-answer { /* styles... */ }
  </style>
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />

  <!-- Ringing Phone Animation Overlay -->
  <div id="phone-animation-overlay" class="hidden">
    <div class="phone-icon">
      <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
    </div>
    <p class="click-to-answer">Click to answer</p>
  </div>
</body>
