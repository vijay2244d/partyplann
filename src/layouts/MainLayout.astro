---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<script>
  // No script needed for this component
</script>

<style is:global>
  /* CSS Reset & Base Styles */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 16px; scroll-behavior: smooth; }
  body { font-family: 'Poppins', sans-serif; background-color: #F9F4FB; color: #333; line-height: 1.6; }
  img { max-width: 100%; height: auto; display: block; }
  h1, h2, h3, h4 { line-height: 1.2; margin-bottom: 1rem; }

  /* Fluid Typography */
  :root {
    --font-size-base: clamp(1rem, 0.9vw + 0.5rem, 1.1rem);
    --font-size-lg: clamp(1.25rem, 1.5vw + 0.5rem, 1.5rem);
    --font-size-xl: clamp(1.5rem, 2.5vw + 0.5rem, 2.5rem);
    --font-size-xxl: clamp(2rem, 4vw + 0.5rem, 4rem);
  }

  h1 { font-size: var(--font-size-xxl); }
  h2 { font-size: var(--font-size-xl); }
  h3 { font-size: var(--font-size-lg); }
  body { font-size: var(--font-size-base); }

  /* Main Layout Structure */
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  main {
    flex-grow: 1;
    padding: clamp(1.5rem, 5vw, 3rem) clamp(1rem, 4vw, 2.5rem);
  }

  /* Utility Classes */
  .container { max-width: 1200px; margin: 0 auto; padding: 0 clamp(1rem, 4vw, 2rem); }
  .text-center { text-align: center; }

  /* Header & Footer */
  /* These will be styled in their own components */
</style>

<style>
  /* Scoped styles for the layout component can go here if needed */
</style>

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Party Time - Plan Your Perfect Event</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&family=Pacifico&display=swap" rel="stylesheet">
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
