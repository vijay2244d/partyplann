---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Dock from '../components/Dock.astro';
import { ViewTransitions } from 'astro:transitions';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Party Time - Plan Your Perfect Event</title>
    <meta name="description" content="Party Time is a full-service event planning company specializing in creating unforgettable experiences. From weddings and corporate events to birthday parties and more, we handle every detail to make your celebration a success." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&family=Pacifico&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Roboto:wght@400&display=swap" rel="stylesheet">
    <ViewTransitions />

    <style>
        :root {
            --background-color: #fff;
            --text-color: #333;
            --header-bg: #fff;
            --header-shadow: 0 2px 10px rgba(0,0,0,0.05);
            --logo-color: #8a4baf;
            --nav-link-color: #333;
            --nav-link-hover-color: #8a4baf;
            --cta-bg: #8a4baf;
            --cta-text-color: #fff;
            --cta-hover-shadow: 0 5px 15px rgba(138, 75, 175, 0.3);
            --hamburger-color: #333;
            --card-bg-color: #f9f9f9;
            --input-border-color: #ccc;
            --input-bg-color: #fff;
        }

        [data-theme="dark"] {
            --background-color: #121212;
            --text-color: #fff;
            --header-bg: #1e1e1e;
            --header-shadow: 0 2px 10px rgba(255,255,255,0.05);
            --logo-color: #a36ac7;
            --nav-link-color: #fff;
            --nav-link-hover-color: #a36ac7;
            --cta-bg: #a36ac7;
            --cta-hover-shadow: 0 5px 15px rgba(163, 106, 199, 0.3);
            --hamburger-color: #fff;
            --card-bg-color: #1e1e1e;
            --input-border-color: #555;
            --input-bg-color: #2c2c2c;
        }

        body {
            background-color: var(--background-color);
            color: var(--text-color);
        }

        header {
            background-color: var(--header-bg);
            box-shadow: var(--header-shadow);
        }

        .logo a {
            color: var(--logo-color);
            cursor: pointer;
        }

        .nav-links a {
            color: var(--nav-link-color);
        }

        .nav-links a:hover, .nav-links a.is-active {
            color: var(--nav-link-hover-color);
        }

        .cta-button-header {
            background-color: var(--cta-bg);
            color: var(--cta-text-color) !important;
        }

        .cta-button-header:hover {
            box-shadow: var(--cta-hover-shadow);
        }

        .hamburger span {
            background-color: var(--hamburger-color);
        }
        
        .contact-wrapper, .map-wrapper {
            background: var(--background-color);
        }
    </style>
</head>
<body>
    <Header />
    <main>
        <slot />
    </main>
    <Dock />
    <Footer />
    <script>
      const themeToggle = document.getElementById('theme-toggle');
      
      const applyTheme = () => {
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme) {
          document.documentElement.setAttribute('data-theme', savedTheme);
        } else {
          const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
        }
      };

      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          const currentTheme = document.documentElement.getAttribute('data-theme');
          const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', newTheme);
          localStorage.setItem('theme', newTheme);
        });
      }

      document.addEventListener('astro:page-load', applyTheme);
      applyTheme();
    </script>
</body>
</html>
